# TWCC Proxy 環境變數設定範例
# 複製此檔為 .env 並填入實際值，或直接設定系統環境變數
# Windows PowerShell 可使用 twcc_env.ps1 一次設定

# ── TWCC 帳號（必填）────────────────────────────────────
TWCC_SSH_USER=your_username          # TWCC 帳號（如 tcpsr001）
TWCC_SSH_HOST=xdata1.twcc.ai         # TWCC SSH 主機（通常不需更改）
TWCC_SSH_PORT=22

# ── SSH 金鑰路徑（預設 ~/.ssh/id_ed25519）────────────────
# TWCC_SSH_KEY=C:\Users\YourName\.ssh\id_ed25519

# ── HFS 路徑（預設依帳號自動組成）───────────────────────
# TWCC_HFS_WORK_DIR=/work/your_username
# TWCC_HFS_PROXY_DIR=/work/your_username/proxy
# TWCC_INFERENCE_SCRIPT=/work/your_username/scripts/inference.sh

# ── TWCC CLI 資料目錄（Windows）─────────────────────────
TWCC_DATA_PATH=C:\Users\YourName\.twcc_data

# ── 模型設定 ─────────────────────────────────────────────
TWCC_DEFAULT_MODEL=crystalmind       # crystalmind / gemmapro / gemmapro-r

# ── 容器映像（通常不需更改）─────────────────────────────
# TWCC_CCS_IMAGE_TYPE=PyTorch
# TWCC_CCS_IMAGE=pytorch-24.08-py3:latest
