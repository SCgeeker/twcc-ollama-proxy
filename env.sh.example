#!/bin/bash
# TWCC HFS 環境變數設定
# 上傳至：/home/<username>/env.sh
# 上傳指令：sftp -i ~/.ssh/id_ed25519 <username>@xdata1.twcc.ai
#           put env.sh /home/<username>/env.sh

export OLLAMA_MODELS=/home/$(whoami)/ollama_models
export OLLAMA_HOST=0.0.0.0:11434
export HF_TOKEN=YOUR_HUGGINGFACE_TOKEN   # 從 https://huggingface.co/settings/tokens 取得
